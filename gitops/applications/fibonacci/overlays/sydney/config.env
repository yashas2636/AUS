JDK_JAVA_OPTIONS=-javaagent:/opt/newrelic/newrelic.jar -XX:MaxRAMPercentage=65.0 -XX:ActiveProcessorCount=1 -XX:InitialRAMPercentage=65.0 -XX:+ExitOnOutOfMemoryError -XX:+UseG1GC -XX:+UseStringDeduplication -Dspring.profiles.active=prod -Dserver.port=8080 -Dnewrelic.config.process_host.display_name=prod-syd-fibonacci-service -Dnewrelic.config.labels=cluster:prod-syd;datacentre:sydney
NEW_RELIC_APP_NAME=fibonacci-service
NEW_RELIC_METADATA_KUBERNETES_CLUSTER_NAME=prod-syd
NEW_RELIC_METADATA_KUBERNETES_DEPLOYMENT_NAME=fibonacci-service
NEW_RELIC_METADATA_KUBERNETES_NAMESPACE_NAME=fibonacci
SERVER_SHUTDOWN=graceful
SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=60s
