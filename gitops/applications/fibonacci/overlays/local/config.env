# Local dev — NR agent disabled, DEBUG logging, no cluster constraints
JDK_JAVA_OPTIONS=-XX:MaxRAMPercentage=65.0 -XX:+UseG1GC -Dspring.profiles.active=local -Dserver.port=8080
NEW_RELIC_APP_NAME=fibonacci-service-local
NEW_RELIC_METADATA_KUBERNETES_CLUSTER_NAME=local
NEW_RELIC_METADATA_KUBERNETES_DEPLOYMENT_NAME=fibonacci-service
NEW_RELIC_METADATA_KUBERNETES_NAMESPACE_NAME=fibonacci
SERVER_SHUTDOWN=graceful
SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=60s
